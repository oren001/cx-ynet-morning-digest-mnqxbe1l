# Cloudflare Worker Environment Variables Example
# Copy this file to .env for local development
# For production, set these in Cloudflare Dashboard under Worker Settings > Variables

# KV Namespace IDs (create these in Cloudflare Dashboard)
# Run: wrangler kv:namespace create "USER_PREFERENCES"
# Run: wrangler kv:namespace create "READING_HISTORY"
# Run: wrangler kv:namespace create "ARTICLE_CACHE"
# Run: wrangler kv:namespace create "DIGESTS"
USER_PREFERENCES_ID=your_user_preferences_namespace_id
READING_HISTORY_ID=your_reading_history_namespace_id
ARTICLE_CACHE_ID=your_article_cache_namespace_id
DIGESTS_ID=your_digests_namespace_id

# Scraping Configuration
YNET_BASE_URL=https://www.ynet.co.il
YNET_NEWS_URL=https://www.ynet.co.il/news
MAX_ARTICLES_PER_SCRAPE=50
SCRAPE_TIMEOUT_MS=30000
USER_AGENT=Mozilla/5.0 (compatible; PersonalDigestBot/1.0; +https://yourworker.workers.dev/about)

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=10
RATE_LIMIT_DELAY_MS=6000
RESPECT_ROBOTS_TXT=true

# Digest Generation
DIGEST_GENERATION_HOUR=6
DIGEST_ARTICLES_COUNT=10
MIN_PREFERENCE_SCORE=0.3

# Machine Learning / Preference Algorithm
CATEGORY_WEIGHT=0.4
KEYWORD_WEIGHT=0.3
AUTHOR_WEIGHT=0.2
RECENCY_WEIGHT=0.1
LEARNING_RATE=0.05
MIN_READING_TIME_SECONDS=15

# API Configuration
API_VERSION=v1
CORS_ALLOWED_ORIGINS=*
MAX_REQUEST_SIZE_KB=100

# Session & Authentication (optional, for future enhancements)
SESSION_SECRET=your_random_session_secret_here_min_32_chars
SESSION_EXPIRY_DAYS=30

# Analytics & Monitoring (optional)
ENABLE_ANALYTICS=true
LOG_LEVEL=info

# Email Delivery (optional, for future email digest feature)
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=digest@yourdomain.com

# Feature Flags
ENABLE_DAILY_CRON=true
ENABLE_PREFERENCE_LEARNING=true
ENABLE_CACHE=true
CACHE_TTL_HOURS=24

# Development Settings
ENVIRONMENT=development
DEBUG_MODE=false